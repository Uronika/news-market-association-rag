APP_ENV=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/news_market_rag

USE_MOCK_DATA=false

NEWS_PROVIDER=yahoo_finance
ENABLE_GDELT=true
GDELT_BASE_URL=https://api.gdeltproject.org/api/v2/doc/doc
YAHOO_FINANCE_SEARCH_URL=https://query1.finance.yahoo.com/v1/finance/search
YAHOO_FINANCE_CHART_URL=https://query1.finance.yahoo.com/v8/finance/chart

MARKET_PROVIDER=yahoo_finance

ALPHA_VANTAGE_API_KEY=replace-if-needed
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query

TWELVE_DATA_API_KEY=replace-if-needed
TWELVE_DATA_BASE_URL=https://api.twelvedata.com

NASDAQ_DATA_LINK_API_KEY=replace-if-needed
NASDAQ_DATA_LINK_BASE_URL=https://data.nasdaq.com/api/v3

STOOQ_BASE_URL=https://stooq.com/q/d/l/
STOOQ_SYMBOL_SUFFIX=.us

LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=replace-if-needed
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_REQUEST_TIMEOUT_SECONDS=90

# Optional. If you use Clash locally, uncomment in your real .env:
# PROXY_URL=http://127.0.0.1:7890

EMBED_PROVIDER=none
EMBED_MODEL_NAME=BAAI/bge-small-zh-v1.5

# Runtime fail-fast controls
EXTERNAL_REQUEST_TIMEOUT_SECONDS=8
YAHOO_NEWS_QUERY_LIMIT=3
RELATED_MARKET_ENTITY_LIMIT=3
# 0 means no whole-analysis timeout. Set a positive number to return partial results after that many seconds.
ANALYSIS_TOTAL_TIMEOUT_SECONDS=0
